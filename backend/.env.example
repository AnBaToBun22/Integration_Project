# -------------------------
# Dashboard Integration API
# Environment Configuration
# -------------------------

# Security Key for JWT and Flask Sessions
SECRET_KEY=your_super_secret_key_here

# 1. Internal Auth/RBAC Database
# By default, uses local SQLite. Can be changed to Postgres (postgresql://user:pass@localhost/db_name)
AUTH_DATABASE_URL=sqlite:///auth_dashboard.db

# 2. HR Database (SQL Server - HUMAN_2025)
HR_DB_SERVER=your_sql_server_host_ip_or_name
HR_DB_NAME=HUMAN_2025
HR_DB_USER=sa
HR_DB_PASSWORD=your_hr_db_password

# 3. Payroll Database (MySQL - payroll)
PAYROLL_DB_HOST=127.0.0.1
PAYROLL_DB_USER=root
PAYROLL_DB_PASSWORD=your_payroll_db_password
PAYROLL_DB_NAME=payroll
